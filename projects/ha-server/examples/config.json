{
    "server": {
        "host": "0.0.0.0",
        "port": 8080,
        "worker_threads": 4
    },
    "backends": [
        {
            "host": "127.0.0.1",
            "port": 8081,
            "weight": 5
        },
        {
            "host": "127.0.0.1",
            "port": 8082,
            "weight": 3
        },
        {
            "host": "127.0.0.1",
            "port": 8083,
            "weight": 2
        }
    ],
    "load_balancer": {
        "algorithm": "weighted_round_robin"
    },
    "health_checker": {
        "enabled": true,
        "interval_ms": 5000,
        "timeout_ms": 3000,
        "failure_threshold": 3,
        "success_threshold": 1
    },
    "connection_pool": {
        "max_size": 100,
        "min_size": 1,
        "idle_timeout_ms": 60000,
        "connect_timeout_ms": 5000
    }
