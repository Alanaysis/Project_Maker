# EditorConfig 配置文件
# https://editorconfig.org

root = true

# 全局设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C++ 文件
[*.{cpp,h,hpp,cc,cxx,hxx}]
indent_style = space
indent_size = 2
tab_width = 2

# CMake 文件
[CMakeLists.txt]
indent_style = space
indent_size = 2

[*.cmake]
indent_style = space
indent_size = 2

# 配置文件
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

# Shell 脚本
[*.sh]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Makefile
[Makefile]
indent_style = tab

# XML 文件
[*.xml]
indent_style = space
indent_size = 2

# Python 文件
[*.py]
indent_style = space
indent_size = 4

# Java 文件
[*.java]
indent_style = space
indent_size = 4

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2

# Go 文件
[*.go]
indent_style = tab
indent_size = 4

# Rust 文件
[*.rs]
indent_style = space
indent_size = 4

# SQL 文件
[*.sql]
indent_style = space
indent_size = 2

# HTML/CSS
[*.{html,css,scss,less}]
indent_style = space
indent_size = 2

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 2

# YAML 配置
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# JSON 配置
[*.json]
indent_style = space
indent_size = 2

# 配置文件
[*.{cfg,conf,ini}]
indent_style = space
indent_size = 2

# 文本文件
[*.txt]
charset = utf-8
end_of_line = lf

# Git 配置
[.gitattributes]
indent_style = tab
indent_size = 4

# 编辑器配置
[.editorconfig]
indent_style = space
indent_size = 2

# Clang-Format 配置
[.clang-format]
indent_style = space
indent_size = 2

# Clang-Tidy 配置
[.clang-tidy]
indent_style = space
indent_size = 2

# VS Code 配置
[.vscode/*.json]
indent_style = space
indent_size = 2

# CLion 配置
[.idea/*.xml]
indent_style = space
indent_size = 2
