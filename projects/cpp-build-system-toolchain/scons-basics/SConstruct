# ============================================================================
# SCons 构建系统基础示例
# 本文件展示 SCons 的基本用法，包括：
# - 环境配置
# - 静态库/动态库创建
# - 可执行文件创建
# - 测试配置
# ============================================================================

import os

# ============================================================================
# 1. 创建构建环境
# ============================================================================
env = Environment(
    CXX='g++',
    CXXFLAGS=['-std=c++17', '-Wall', '-Wextra', '-Wpedantic'],
    CPPPATH=['include'],
)

# 根据构建类型设置编译选项
debug = ARGUMENTS.get('debug', 0)
if int(debug):
    env.Append(CXXFLAGS=['-g', '-O0'])
else:
    env.Append(CXXFLAGS=['-O2', '-DNDEBUG'])

# ============================================================================
# 2. 编译源文件
# ============================================================================
# 静态库
math_utils = env.StaticLibrary(
    target='lib/math_utils',
    source=['src/math_utils.cpp'],
)

# 动态库
string_utils = env.SharedLibrary(
    target='lib/string_utils',
    source=['src/string_utils.cpp'],
)

# ============================================================================
# 3. 创建可执行文件
# ============================================================================
hello = env.Program(
    target='bin/hello_world',
    source=['src/hello.cpp'],
    LIBS=['math_utils', 'string_utils'],
    LIBPATH=['lib'],
)

# 确保库在可执行文件之前构建
Depends(hello, [math_utils, string_utils])

# ============================================================================
# 4. 安装规则
# ============================================================================
install_bin = env.Install('install/bin', hello)
install_lib = env.Install('install/lib', [math_utils, string_utils])
env.Alias('install', [install_bin, install_lib])

# ============================================================================
# 5. 测试
# ============================================================================
test_math = env.Program(
    target='bin/test_math',
    source=['tests/test_math.cpp'],
    LIBS=['math_utils'],
    LIBPATH=['lib'],
)

test = env.Alias('test', [test_math], 'bin/test_math')

# 默认构建所有目标
Default([hello, test_math])
