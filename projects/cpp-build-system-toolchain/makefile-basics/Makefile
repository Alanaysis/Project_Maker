# ============================================================================
# Makefile 基础示例
# 本文件展示 Makefile 的基本用法，包括：
# - 变量定义
# - 模式规则
# - 依赖管理
# - 自动变量
# - 伪目标
# ============================================================================

# ============================================================================
# 1. 变量定义
# ============================================================================
CXX := g++
CXXFLAGS := -std=c++17 -Wall -Wextra -Wpedantic
CPPFLAGS := -Iinclude
LDFLAGS :=
LDLIBS :=

# 构建类型
BUILD_TYPE ?= release
ifeq ($(BUILD_TYPE),debug)
    CXXFLAGS += -g -O0 -DDEBUG
else
    CXXFLAGS += -O2 -DNDEBUG
endif

# 目录定义
SRC_DIR := src
INC_DIR := include
BUILD_DIR := build
BIN_DIR := $(BUILD_DIR)/bin
LIB_DIR := $(BUILD_DIR)/lib
OBJ_DIR := $(BUILD_DIR)/obj

# 源文件和目标文件
SRCS := $(wildcard $(SRC_DIR)/*.cpp)
OBJS := $(patsubst $(SRC_DIR)/%.cpp,$(OBJ_DIR)/%.o,$(SRCS))

# 库文件
MATH_LIB := $(LIB_DIR)/libmath_utils.a
STRING_LIB := $(LIB_DIR)/libstring_utils.so

# 可执行文件
HELLO := $(BIN_DIR)/hello_world

# ============================================================================
# 2. 默认目标
# ============================================================================
.PHONY: all
all: $(HELLO)

# ============================================================================
# 3. 创建目录
# ============================================================================
$(OBJ_DIR) $(LIB_DIR) $(BIN_DIR):
	mkdir -p $@

# ============================================================================
# 4. 编译源文件为对象文件
# ============================================================================
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp | $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) $(CPPFLAGS) -c $< -o $@

# ============================================================================
# 5. 创建静态库
# ============================================================================
MATH_OBJS := $(OBJ_DIR)/math_utils.o

$(MATH_LIB): $(MATH_OBJS) | $(LIB_DIR)
	ar rcs $@ $^

# ============================================================================
# 6. 创建动态库
# ============================================================================
STRING_OBJS := $(OBJ_DIR)/string_utils.o

$(STRING_LIB): $(STRING_OBJS) | $(LIB_DIR)
	$(CXX) -shared -o $@ $^

# ============================================================================
# 7. 链接可执行文件
# ============================================================================
HELLO_OBJS := $(OBJ_DIR)/hello.o

$(HELLO): $(HELLO_OBJS) $(MATH_LIB) $(STRING_LIB) | $(BIN_DIR)
	$(CXX) $(LDFLAGS) $< -L$(LIB_DIR) -lmath_utils -lstring_utils -o $@

# ============================================================================
# 8. 测试目标
# ============================================================================
TEST := $(BIN_DIR)/test_math

$(TEST): $(OBJ_DIR)/test_math.o $(MATH_LIB) | $(BIN_DIR)
	$(CXX) $(LDFLAGS) $< -L$(LIB_DIR) -lmath_utils -o $@

.PHONY: test
test: $(TEST)
	$(TEST)

# ============================================================================
# 9. 清理目标
# ============================================================================
.PHONY: clean
clean:
	rm -rf $(BUILD_DIR)

# ============================================================================
# 10. 安装目标
# ============================================================================
PREFIX ?= /usr/local

.PHONY: install
install: $(HELLO)
	install -d $(DESTDIR)$(PREFIX)/bin
	install -d $(DESTDIR)$(PREFIX)/lib
	install -m 755 $(HELLO) $(DESTDIR)$(PREFIX)/bin/
	install -m 644 $(MATH_LIB) $(DESTDIR)$(PREFIX)/lib/
	install -m 755 $(STRING_LIB) $(DESTDIR)$(PREFIX)/lib/

# ============================================================================
# 11. 帮助信息
# ============================================================================
.PHONY: help
help:
	@echo "可用目标:"
	@echo "  all      - 构建所有目标 (默认)"
	@echo "  test     - 运行测试"
	@echo "  clean    - 清理构建文件"
	@echo "  install  - 安装到 $(PREFIX)"
	@echo "  help     - 显示此帮助信息"
	@echo ""
	@echo "变量:"
	@echo "  BUILD_TYPE=debug|release  - 构建类型 (默认: release)"
	@echo "  PREFIX=<path>             - 安装前缀 (默认: /usr/local)"
