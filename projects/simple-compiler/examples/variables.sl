// Variable Examples
// Demonstrates variable declaration and assignment

// Integer variables
let x = 10;
let y = 20;
print("x = ", x);
print("y = ", y);

// Reassignment
x = 30;
print("x after reassignment = ", x);

// Expressions
let sum = x + y;
let product = x * y;
print("sum = ", sum);
print("product = ", product);

// Boolean variables
let is_true = true;
let is_false = false;
print("is_true = ", is_true);
print("is_false = ", is_false);

// String variables
let greeting = "Hello";
let name = "World";
let message = greeting + ", " + name + "!";
print(message);

// Float variables
let pi = 3.14159;
let radius = 5.0;
let area = pi * radius * radius;
print("Area of circle with radius ", radius, " = ", area);
