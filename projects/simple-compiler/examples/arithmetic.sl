// Arithmetic Operations
let a = 10;
let b = 3;

print("a = ", a);
print("b = ", b);
print("a + b = ", a + b);
print("a - b = ", a - b);
print("a * b = ", a * b);
print("a / b = ", a / b);
print("a % b = ", a % b);

// Operator precedence
let result = 2 + 3 * 4;
print("2 + 3 * 4 = ", result);

let result2 = (2 + 3) * 4;
print("(2 + 3) * 4 = ", result2);
