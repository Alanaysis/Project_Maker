.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ==================== Virtual environments ====================

venv/
env/
ENV/
.env
.venv

# ==================== IDE ====================

# PyCharm
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# Spyder
.spyderproject
.spyproject

# Jupyter
.ipynb_checkpoints/

# ==================== Testing ====================

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

